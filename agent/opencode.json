{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "greennode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "GreenNode MaaS",
      "options": {
        "baseURL": "{env:GREENNODE_BASE_URL}",
        "apiKey": "{env:GREENNODE_API_KEY}"
      },
      "models": {
        "google/gemma-4-31b-it": { "name": "Gemma 4 31B" },
        "qwen/qwen3-5-27b": { "name": "Qwen 3.5 27B" },
        "minimax/minimax-m2.5": { "name": "MiniMax M2.5" }
      }
    }
  },
  "model": "greennode/google/gemma-4-31b-it",
  "mcp": {
    "fdl": {
      "type": "remote",
      "url": "{env:FDL_MCP_URL}",
      "//": "Parked until the data layer lands. Flip to true when FDL_MCP_URL is a live endpoint.",
      "enabled": false
    }
  },
  "agent": {
    "hr": {
      "description": "HR domain — headcount, org, hiring, leave (HRCore/Odoo).",
      "mode": "primary",
      "prompt": "{file:./agents/hr.md}",
      "tools": { "fdl*": true, "write": false, "edit": false, "bash": false }
    },
    "legal": {
      "description": "Legal domain — contracts, parties, dates, document metadata.",
      "mode": "primary",
      "prompt": "{file:./agents/legal.md}",
      "tools": { "fdl*": true, "write": false, "edit": false, "bash": false }
    },
    "fa": {
      "description": "Finance & Accounting domain — ERP, e-forms, comp.",
      "mode": "primary",
      "prompt": "{file:./agents/fa.md}",
      "tools": { "fdl*": true, "write": false, "edit": false, "bash": false }
    }
  }
}
