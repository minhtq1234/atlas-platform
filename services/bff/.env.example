# Atlas BFF — configuration. Copy to .env (gitignored) and fill in.

PORT=8787
WEB_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Generation runtime ───────────────────────────────────────────────
# direct   = BFF calls the model (OpenAI-compatible) itself
# opencode = BFF drives an OpenCode server (see agent/)
AGENT_RUNTIME=direct

# ── GreenNode MaaS (direct mode) ─────────────────────────────────────
# OpenAI-compatible LLM endpoint. Get an AIP key + model path with:
#   AIP_KEY=... bash scripts/greennode-connect.sh          (verify)
#   GREENNODE_CLIENT_ID=... GREENNODE_CLIENT_SECRET=... \
#     bash scripts/greennode-connect.sh --create-key atlas-bff   (provision)
MODEL_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
MODEL_API_KEY=
# The model *path* from the AIP models list (NOT the display code):
MODEL_NAME=
# Sovereignty egress allowlist — non-loopback hosts must be https AND match:
MODEL_ALLOWED_HOSTS=vngcloud.vn
MODEL_TIMEOUT_MS=30000

# ── OpenCode mode (opencode) ─────────────────────────────────────────
OPENCODE_URL=http://127.0.0.1:4096
OPENCODE_PROVIDER=greennode
OPENCODE_AGENT=hr
OPENCODE_TIMEOUT_MS=60000
